{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "outDir": "dist",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk": ["./src/types/shims/openclaw-plugin-sdk.d.ts"],
      "openclaw/context-engine/types": ["./src/types/shims/openclaw-context-engine-types.d.ts"],
      "@lancedb/lancedb": ["./src/types/shims/lancedb.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "openclaw.plugin.json", "package.json"],
  "exclude": ["dist"]
}
