{
  "name": "@lancedb-claw/context-lancedb",
  "version": "2026.3.14",
  "description": "LanceDB-backed context engine plugin for OpenClaw — extracted from openclaw/extensions/context-lancedb",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "pack:check": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "apache-arrow": "18.1.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "openclaw": "2026.4.15"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    },
    "@mariozechner/pi-agent-core": {
      "optional": false
    },
    "@mariozechner/pi-coding-agent": {
      "optional": false
    }
  },
  "optionalDependencies": {
    "node-llama-cpp": "3.18.1"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "0.66.1",
    "@mariozechner/pi-coding-agent": "0.66.1",
    "openclaw": "2026.4.15",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
